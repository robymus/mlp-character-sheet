{
    "name": "mlp-character-sheet",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "dev:wrangler": "vite build && wrangler dev"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260317.1",
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@tsconfig/svelte": "^5.0.8",
        "@types/node": "^24.12.0",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.15.2",
        "globals": "^17.4.0",
        "jsdom": "^29.0.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.1",
        "svelte": "^5.53.7",
        "svelte-check": "^4.4.5",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^8.0.0",
        "vitest": "^4.1.0",
        "wrangler": "^4.75.0"
    },
    "dependencies": {
        "@auth/d1-adapter": "^1.11.1",
        "@auth/sveltekit": "^1.11.1",
        "@sveltejs/kit": "^2.55.0",
        "drizzle-orm": "^0.45.1"
    }
}
